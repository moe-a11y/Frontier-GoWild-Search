# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# For Gmail you MUST use an "App Password" (Google Account > Security >
# 2-Step Verification > App passwords), NOT your normal login password.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_sender_address@gmail.com
SMTP_PASSWORD=your_16_char_app_password
EMAIL_FROM=your_sender_address@gmail.com
